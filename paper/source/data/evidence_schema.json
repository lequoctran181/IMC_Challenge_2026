{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lequoctran181/IMC_Challenge_2026/blob/main/paper/source/data/evidence_schema.json",
  "title": "IMC simplifygeometry experiment evidence event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "evidence_level",
    "submission_id",
    "parent_submission_id",
    "changed_branch",
    "intervention",
    "verdict",
    "official_score",
    "output_counts",
    "source_sha256",
    "local_metrics",
    "interpretation",
    "captured_at",
    "source_commit",
    "evidence_paths",
    "evidence_sha256",
    "candidate_output_sha256",
    "unchanged_output_sha256",
    "geometry_audit_path",
    "isolation_status",
    "artifact_limitations"
  ],
  "properties": {
    "event_id": {"type": "string", "minLength": 1},
    "evidence_level": {
      "type": "array",
      "items": {"enum": ["Official", "Reconstructed", "Experimental", "Inference"]},
      "uniqueItems": true
    },
    "submission_id": {"type": ["integer", "null"]},
    "parent_submission_id": {"type": ["integer", "null"]},
    "changed_branch": {"type": ["string", "null"]},
    "intervention": {"type": "string"},
    "verdict": {"enum": ["Accepted", "Rejected", "Partial (6/7)", "TLE", "Diagnostic accepted", "Local only", null]},
    "official_score": {"type": ["number", "null"]},
    "output_counts": {
      "oneOf": [
        {"type": "null"},
        {"type": "array", "items": {"type": "integer"}, "minItems": 6, "maxItems": 6}
      ]
    },
    "source_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "local_metrics": {"type": "object"},
    "interpretation": {"type": "string"},
    "captured_at": {"type": ["string", "null"]},
    "source_commit": {"type": ["string", "null"], "pattern": "^[0-9a-f]{7,40}$"},
    "evidence_paths": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "evidence_sha256": {"type": "object", "additionalProperties": {"type": "string", "pattern": "^[0-9a-f]{64}$"}},
    "candidate_output_sha256": {"type": "array", "items": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "uniqueItems": true},
    "unchanged_output_sha256": {"type": "object", "additionalProperties": {"type": "string", "pattern": "^[0-9a-f]{64}$"}},
    "geometry_audit_path": {"type": ["string", "null"]},
    "isolation_status": {"enum": ["verified-counts", "not-applicable", "historical-missing-counts", "local-controlled"]},
    "artifact_limitations": {"type": "string"},
    "carrier_type": {"type": ["string", "null"]},
    "base_count": {"type": ["integer", "null"]},
    "payload": {"type": ["integer", "string", "null"]}
  }
}
